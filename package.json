{
  "name": "@mezmoinc/commitlint-config",
  "version": "1.0.0",
  "description": "Shareable commitlint configuration for Mezmo Inc.",
  "keywords": [
    "commitlint",
    "mezmo"
  ],
  "license": "MIT",
  "author": "eric.satterwhite <eric.satterwhite@mezmo.com>",
  "type": "commonjs",
  "bin": {
    "commitlint-mzm": "./bin/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "homepage": "https://github.com/mezmo/commitline-config#readme",
  "bugs": {
    "url": "https://github.com/mezmo/commitline-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mezmo/commitlint-config.git"
  },
  "scripts": {
    "tap": "tap",
    "pretest": "rm -rf .tap*",
    "test": "./scripts/test-ci.sh",
    "lint": "eslint ",
    "lint:fix": "npm run lint -- --fix",
    "prelint:ci": "rm -f .eslint.json",
    "lint:ci": "eslint -f json-relative > .eslint.json || true",
    "release": "npx semantic-release",
    "release:dry": "npm run release -- --no-ci --dry-run --branches=${BRANCH_NAME:-main}",
    "commitlint": "./bin/cli.js"
  },
  "tap": {
    "browser": false,
    "show-full-coverage": true,
    "statements": 100,
    "branches": 100,
    "functions": 100,
    "lines": 100,
    "coverage-report": [
      "text",
      "text-summary",
      "lcov",
      "json",
      "json-summary",
      "html"
    ],
    "output-file": ".tap-out",
    "files": [
      "test/unit",
      "test/integration"
    ]
  },
  "dependencies": {
    "@commitlint/lint": "^20.5.0",
    "@commitlint/load": "^20.5.0",
    "@commitlint/parse": "^20.5.0",
    "eslint-config-logdna": "^8.0.1",
    "gitlog": "^5.1.0"
  },
  "devDependencies": {
    "@mezmoinc/release-config-core": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-formatter-json-relative": "^0.1.0",
    "execa": "^9.6.1",
    "tap": "^21.7.2"
  }
}
